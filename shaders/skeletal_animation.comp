            continue;
        }
        
        // Calculate bone matrix index (instance offset + bone id)
        uint boneMatrixIndex = instance.boneMatrixOffset + boneId;
        
        // Bounds check for bone matrix array
        if (boneMatrixIndex >= boneMatrices.length()) {
            continue;
        }
        
        // Get bone transformation matrix
