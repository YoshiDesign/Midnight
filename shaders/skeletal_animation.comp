        if (abs(totalWeight - 1.0) > 0.001) {
            skinnedPosition /= totalWeight;
            skinnedNormal /= totalWeight;
        }
    }
    */
    
    // Store the transformed vertex data
    outputVertices[vertexIndex].position = skinnedPosition.xyz;
    outputVertices[vertexIndex].normal = normalize(skinnedNormal);
    outputVertices[vertexIndex].color = instanceColor;  // Debug: Use instance color
    outputVertices[vertexIndex].texCoord = inputVertex.texCoord;
} 