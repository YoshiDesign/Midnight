#version 450

// Local workgroup size - process vertices in groups of 64
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

// Structure definitions (must be outside buffer blocks)
struct InstanceAnimationData {
    mat4 modelMatrix;
    float animationTime;
    int animationClipIndex;
    int boneMatrixOffset;
    int boneCount;
    vec4 animationParams; // speed, loop, etc.
};

struct AnimatedVertex {
    vec3 position;
    vec3 color;
    vec3 normal;
    vec2 texCoord;
    ivec4 boneIds;    // Bone indices (up to 4 per vertex)
    vec4 boneWeights; // Bone weights (up to 4 per vertex)
};

// Transformed vertex structure (output) - matches transformed_shader.vert
struct TransformedVertex {
    vec3 position;     // Already transformed position
    vec3 color;        // Color data
    vec3 normal;       // Already transformed normal
    vec2 texCoord;     // Texture coordinates
    // NO bone data - transformation already applied!
};

// Animation uniforms (Set 3) - matches our descriptor set layout
layout(set = 3, binding = 0) uniform AnimationUbo {
    float deltaTime;
    uint totalInstances;
    uint maxBonesPerInstance;
    uint verticesPerInstance;
    vec4 debugParams;
} animUbo;

// Bone transformation matrices
layout(set = 3, binding = 1, std430) restrict readonly buffer BoneMatricesSSBO {
    mat4 boneMatrices[];
};

// Per-instance animation data
layout(set = 3, binding = 2, std430) restrict readonly buffer InstanceAnimationSSBO {
    InstanceAnimationData instances[];
};

// Input animated vertices (original mesh data)
layout(set = 3, binding = 3, std430) restrict readonly buffer InputVerticesSSBO {
    AnimatedVertex inputVertices[];
};

// Output transformed vertices (result of animation)
layout(set = 3, binding = 4, std430) restrict writeonly buffer OutputVerticesSSBO {
    TransformedVertex outputVertices[];
};

void main() {
    uint vertexIndex = gl_GlobalInvocationID.x;
    
    // Early exit if we're beyond the vertex count
    if (vertexIndex >= inputVertices.length()) {
        return;
    }
    
    // Get the input vertex
    AnimatedVertex inputVertex = inputVertices[vertexIndex];
    
    // Initialize output vertex with input data (copy only the fields TransformedVertex has)
    outputVertices[vertexIndex].position = inputVertex.position;
    outputVertices[vertexIndex].color = inputVertex.color;
    outputVertices[vertexIndex].normal = inputVertex.normal;
    outputVertices[vertexIndex].texCoord = inputVertex.texCoord;
    // Note: boneIds and boneWeights are NOT copied - TransformedVertex doesn't have them
    
    // Find which instance this vertex belongs to
    // Calculate vertices per individual instance (all instances have same model)
    uint verticesPerInstance = animUbo.verticesPerInstance / animUbo.totalInstances;
    uint instanceIndex = vertexIndex / verticesPerInstance;
    
    if (instanceIndex >= animUbo.totalInstances) {
        return;
    }
    
    // Debug: Color vertices by instance to verify mapping
    vec3 instanceColor = vec3(1.0);
    if (instanceIndex == 0) instanceColor = vec3(1.0, 0.0, 0.0);      // Red for instance 0
    else if (instanceIndex == 1) instanceColor = vec3(0.0, 1.0, 0.0); // Green for instance 1  
    else if (instanceIndex == 2) instanceColor = vec3(0.0, 0.0, 1.0); // Blue for instance 2
    

    
    // Get instance animation data
    InstanceAnimationData instance = instances[instanceIndex];
    
    // TEMPORARY: Skip bone transformations to test if they're causing the issue
    // Just pass through the original vertex data for now
    vec4 skinnedPosition = vec4(inputVertex.position, 1.0);
    vec3 skinnedNormal = inputVertex.normal;
    
    /* COMMENTED OUT: Original bone transformation code
